# Copy this file to .streamlit/secrets.toml and fill in your values.
# Streamlit loads these as st.secrets["..."]

AZURE_SPEECH_KEY = "<your-speech-key>"
# Use either region or endpoint.
AZURE_SPEECH_REGION = "<your-speech-region>"
# AZURE_SPEECH_ENDPOINT = "https://<your-resource>.cognitiveservices.azure.com/"
